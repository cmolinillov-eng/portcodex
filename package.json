{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:math": "node --test tests/math/*.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:roles": "node scripts/run-e2e-role-matrix.mjs",
    "test:e2e:financial": "node scripts/run-e2e-financial-matrix.mjs",
    "test:e2e:exports": "node scripts/run-e2e-export-matrix.mjs",
    "test:e2e:exports:ui": "node scripts/run-e2e-export-ui-smoke.mjs",
    "check:env:release": "node scripts/check-release-env.mjs",
    "qa:prepush": "npm run -s lint && npm run -s test:e2e:roles && npm run -s test:e2e:financial && npm run -s test:e2e:exports && npm run -s test:e2e:exports:ui"
  },
  "dependencies": {
    "@kamino-finance/farms-sdk": "^3.2.26",
    "@kamino-finance/kliquidity-sdk": "^13.0.0",
    "@solana/kit": "^2.3.0",
    "@splinetool/react-spline": "^4.1.0",
    "@splinetool/runtime": "^1.12.69",
    "@supabase/supabase-js": "^2.97.0",
    "decimal.js": "^10.6.0",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.1",
    "viem": "^2.53.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "playwright": "^1.58.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
